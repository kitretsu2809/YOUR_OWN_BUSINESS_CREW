# Google Gemini API Configuration
GENAI_API_KEY=your_google_genai_api_key_here

# Google Contacts Sync Configuration (optional)
# Option 1: Use OAuth2 (interactive login) - no env var needed
# Option 2: Use service account - set path to credentials JSON
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-credentials.json

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=your_email@gmail.com

# GitHub API Configuration
GITHUB_TOKEN=your_github_personal_access_token

# Web Search Configuration (Bing)
SEARCH_API_KEY=your_bing_search_api_key
